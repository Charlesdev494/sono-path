# Copie para .env e preencha. O .env NUNCA vai para o Git.
#
# VITE_* são públicas: o Vite injeta no bundle do navegador. Não coloque
# segredo aqui — a anon key é pública por design (quem protege os dados é a
# RLS, não o segredo da chave).
VITE_SUPABASE_URL=https://<ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon key>

# --- Somente scripts de backend (seed, testes). Jamais no cliente. ---
SUPABASE_PROJECT_REF=<ref>
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_ANON_KEY=<anon key>
# service_role ignora RLS por completo — trate como senha de root do banco.
SUPABASE_SERVICE_ROLE_KEY=<service role key>
# Personal access token da conta Supabase (sbp_...), usado para rodar migrations.
SUPABASE_ACCESS_TOKEN=<sbp_...>

# Host de preview do Lovable — origem das imagens durante a migração (seed).
# Pode ser removido depois que as imagens estiverem no Storage.
LOVABLE_PREVIEW_HOST=<id-preview-....lovable.app>

# --- Notificações push (VAPID) ---
# Gere um par com: node -e "console.log(require('web-push').generateVAPIDKeys())"
# A pública é injetada no navegador (VITE_); a privada NUNCA sai do servidor.
# Sem estas chaves, o botão de ativar notificações some e nada é enviado.
VITE_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contato exigido pelo protocolo (para o serviço de push falar com você se algo
# der errado). Use um e-mail real do projeto.
VAPID_SUBJECT=mailto:contato@us360.app

# Segredo que protege o endpoint do cron (/api/cron/notificacoes). Quem chamar
# precisa mandar este valor no header. Gere um aleatório e ponha o mesmo aqui e
# no serviço que dispara o cron.
CRON_SECRET=

# --- Copiloto de IA (Fase 4) — opcional ---
# Deixe em branco e a IA fica dormente: os botões "Gerar com IA" não aparecem
# no painel e as funções recusam. Preencha e o recurso liga sozinho, sem
# deploy nem alteração de código.
#
# A chave só existe no servidor: verificado que ela não aparece em nenhum dos
# arquivos que vão para o navegador.
# ANTHROPIC_API_KEY=sk-ant-...
# Modelo (opcional). Padrão: claude-opus-4-8
# ANTHROPIC_MODEL=claude-opus-4-8
